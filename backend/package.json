{
  "name": "ims-backend",
  "version": "1.0.0",
  "description": "Incident Management System Backend",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage"
  },
  "dependencies": {
    "express": "4.18.2",
    "express-rate-limit": "6.7.0",
    "ws": "8.16.0",
    "ioredis": "5.3.2",
    "mongoose": "7.6.3",
    "pg": "8.11.3",
    "uuid": "9.0.0",
    "winston": "3.11.0",
    "cors": "2.8.5",
    "helmet": "7.1.0",
    "dotenv": "16.4.1",
    "joi": "17.12.1"
  },
  "devDependencies": {
    "jest": "29.7.0",
    "nodemon": "3.0.3",
    "supertest": "6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  }
}