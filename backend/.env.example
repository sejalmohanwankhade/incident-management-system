# Server
PORT=3001
NODE_ENV=development

# PostgreSQL (Source of Truth)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ims_db
POSTGRES_USER=ims_user
POSTGRES_PASSWORD=ims_secret

# MongoDB (Data Lake / NoSQL)
MONGO_URI=mongodb://mongo:27017/ims_signals

# Redis (Cache + TimeSeries Aggregations)
REDIS_HOST=redis
REDIS_PORT=6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=5000

# Debounce window in ms
DEBOUNCE_WINDOW_MS=10000
DEBOUNCE_THRESHOLD=100
